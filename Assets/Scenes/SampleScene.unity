  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 18f24ecdffffa7d41a4d30c8af83c695, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Guard
  popUpFeedbackMsg: '"Press E to talk"'
  session:
    conversationId: guard_south_gate
    startNodeId: meet_guard
    firstTimeNodes:
    - id: meet_guard
      nextId: 
      text: Patrulha tranquila por enquanto. Se Ash te enviar ate aqui, fale comigo.
      flagConversation: 
      dialogueOption: []
    worldStateBranches:
    - requiredFlag: complete_help_south_gate
      nodes:
      - id: guard_after_help
        nextId: 
        text: O portao sul esta seguro por enquanto. Diga ao Ash que agradecemos.
        flagConversation: 
        dialogueOption: []
    - requiredFlag: accepted_quest
      nodes:
      - id: help_guards
        nextId: 
        text: Ash te mandou? Otimo. Precisamos reforcar o portao sul antes do anoitecer.
        flagConversation: find_guard_npc
        dialogueOption:
        - optionText: Claro!
          nextId: 
          flagOptions: complete_help_south_gate
          questToStart: 
          questToComplete: help_south_gate
        - optionText: "Ainda n\xE3o."
          nextId: 
          flagOptions: 
          questToStart: 
          questToComplete: 
