--- !u!114 &1258569463
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1258569458}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 18f24ecdffffa7d41a4d30c8af83c695, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Ash
  popUpFeedbackMsg: '"Press E to talk"'
  session:
    conversationId: meet_ash
    startNodeId: intro_ash
    firstTimeNodes:
    - id: intro_ash
      nextId: offer_quest
      text: "Ol\xE1 Rafael, que bom que voc\xEA est\xE1 aqui... os guardas est\xE3o
        precisando de ajuda no port\xE3o sul."
      flagConversation: meet_npc_ash
      dialogueOption: []
    - id: offer_quest
      nextId: 
      text: "Voc\xEA pode dar uma ajuda?"
      flagConversation: offer_quest_defender_south_gate
      dialogueOption:
      - optionText: Sim!
        nextId: say_yes
        flagOptions: accepted_quest
        questToStart: help_south_gate
        questToComplete: 
      - optionText: "N\xE3o!"
        nextId: say_no
        flagOptions: rejected_quest
        questToStart: 
        questToComplete: 
    - id: say_yes
      nextId: 
      text: Obrigado!
      flagConversation: 
      dialogueOption: []
    - id: say_no
      nextId: 
      text: Ah sim, tudo bem...
      flagConversation: 
      dialogueOption: []
    worldStateBranches:
    - requiredFlag: complete_help_south_gate
      nodes:
      - id: ash_quest_complete
        nextId: 
        text: Que bom que conseguiu ajudar o portao sul. Os guardas vao lembrar disso.
        flagConversation: 
        dialogueOption: []
    - requiredFlag: find_guard_npc
      nodes:
      - id: ash_found_guard
        nextId: 
        text: Voce encontrou os guardas. Se puder, confirme com eles que o portao
          esta seguro.
        flagConversation: 
        dialogueOption: []
    - requiredFlag: accepted_quest
      nodes:
      - id: wait_complete_meet_ash
        nextId: 
        text: Encontrou os guardas? Eles estao ao sul perto da casa do ferreiro.
        flagConversation: wait_quest_complete
        dialogueOption: []
    - requiredFlag: rejected_quest
      nodes:
      - id: quest_rejected
        nextId: 
        text: Mudou de ideia?
        flagConversation: 
        dialogueOption:
        - optionText: Sim!
          nextId: say_yes
          flagOptions: accepted_quest
          questToStart: help_south_gate
          questToComplete: 
        - optionText: "Ainda n\xE3o!"
          nextId: say_no
          flagOptions: 
          questToStart: 
          questToComplete: 
      - id: say_yes
        nextId: 
        text: Ainda bem que mudou de ideia, precisamos da sua ajuda!
        flagConversation: 
        dialogueOption: []
      - id: say_no
        nextId: 
        text: Tudo bem, quando mudar de ideia volte aqui...
        flagConversation: 
        dialogueOption: []
